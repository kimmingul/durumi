{
  "name": "durumi",
  "private": true,
  "version": "0.1.0",
  "description": "Durumi — a paper crane for medical research. Typora-style cross-platform markdown editor.",
  "author": "Min-Gul Kim <kimmingul@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/kimmingul/durumi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimmingul/durumi.git"
  },
  "bugs": {
    "url": "https://github.com/kimmingul/durumi/issues"
  },
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "pnpm build && electron-builder --dir",
    "make:mac": "pnpm build && electron-builder --mac",
    "make:win": "pnpm build && electron-builder --win",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.4",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.3.0",
    "electron-updater": "^6.8.3",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.36.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.1",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^2.0.3",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}

  // this config has no `files`/`include` — that hid the v0.2.16 aiHasKey
  // regression. Add new sub-projects to the `references` list to keep
  // them covered.
  "files": [],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "./tsconfig.web.json" }
  ]
}

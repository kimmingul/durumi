{
  // Leaf project — runs explicitly from `pnpm typecheck` after `tsc --build`.
  // Not composite: composite project boundaries require every imported file
  // to be enumerated, which is intractable for tests that touch src/,
  // electron/, and shared/. Without composite, TS transitively type-checks
  // any imported file under THIS config's options, so renderer/main bugs
  // surfaced via test imports are caught too.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": { "@shared/*": ["shared/*"] }
  },
  "include": ["tests/**/*.ts", "tests/**/*.tsx", "e2e/**/*.ts"]
}
